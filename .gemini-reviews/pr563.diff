+        tracker.register_strategy("c", parent_id="b", metadata={"name": "C"})
+
+        # Assert: correct generation numbers before any cycle
+        assert tracker.strategies["a"]["generation"] == 0
+        assert tracker.strategies["b"]["generation"] == 1
